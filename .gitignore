.claude/

# OS
.DS_Store
Thumbs.db

# Local-only assets — everything under _local/ is gitignored
# (literature PDFs, raw CSVs, OrcaFlex outputs, anything too large or private)
# Exceptions: a README per subdir + .gitkeep so empty subdirs survive
/_local/**
!/_local/data/
!/_local/data/README.md
!/_local/pdfs/
!/_local/pdfs/.gitkeep
